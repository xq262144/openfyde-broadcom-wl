#!/usr/bin/env bash

set -euo pipefail

PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

CONFIG_FILE="${CONFIG_FILE:-/usr/local/etc/broadcom-wl-openfyde.conf}"
CONNECT_SCRIPT="${CONNECT_SCRIPT:-/usr/local/sbin/broadcom-wl-openfyde-wext-connect}"
IFACE="${IFACE:-wlan0}"
WAIT_SECONDS="${WAIT_SECONDS:-90}"
INITIAL_DELAY="${INITIAL_DELAY:-15}"
STATUS_LOG="${STATUS_LOG:-/mnt/stateful_partition/var/log/broadcom-wl-openfyde-autoconnect.log}"

if [[ -f "$CONFIG_FILE" ]]; then
    # shellcheck disable=SC1090
    source "$CONFIG_FILE"
fi

SSID="${SSID:-}"
IFACE="${IFACE:-wlan0}"
WAIT_SECONDS="${WAIT_SECONDS:-90}"
INITIAL_DELAY="${INITIAL_DELAY:-15}"
STATUS_LOG="${STATUS_LOG:-/mnt/stateful_partition/var/log/broadcom-wl-openfyde-autoconnect.log}"

log() {
    printf '[%s] %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$*"
}

if [[ -n "$STATUS_LOG" ]]; then
    mkdir -p "$(dirname "$STATUS_LOG")"
    touch "$STATUS_LOG"
    exec >>"$STATUS_LOG" 2>&1
fi

log "autoconnect invoked"
log "PATH=$PATH"
log "SSID=${SSID:-<unset>} IFACE=$IFACE WAIT_SECONDS=$WAIT_SECONDS INITIAL_DELAY=$INITIAL_DELAY"

if [[ -z "$SSID" ]]; then
    log "[!] SSID is not configured in $CONFIG_FILE"
    exit 1
fi

if [[ ! -x "$CONNECT_SCRIPT" ]]; then
    log "[!] missing connect helper: $CONNECT_SCRIPT"
    exit 1
fi

wait_for_iface() {
    local elapsed=0
    while (( elapsed < WAIT_SECONDS )); do
        if [[ -e "/sys/class/net/$IFACE" ]]; then
            return 0
        fi
        sleep 1
        ((elapsed+=1))
    done
    return 1
}

wait_for_shill() {
    local elapsed=0
    while (( elapsed < WAIT_SECONDS )); do
        if dbus-send --system --print-reply --dest=org.chromium.flimflam / \
            org.chromium.flimflam.Manager.GetProperties >/dev/null 2>&1; then
            return 0
        fi
        sleep 1
        ((elapsed+=1))
    done
    return 1
}

find_saved_passphrase() {
    local profile

    for profile in /home/root/*/shill/shill.profile /var/cache/shill/default.profile; do
        [[ -f "$profile" ]] || continue
        awk -v want="$SSID" '
            /^\[/ {
                if (name == want && pass != "") {
                    print pass
                    exit
                }
                name = ""
                pass = ""
                next
            }
            /^Name=/ {
                sub(/^Name=/, "")
                name = $0
                next
            }
            /^WiFi\.Passphrase=/ {
                sub(/^WiFi\.Passphrase=/, "")
                pass = $0
                next
            }
            END {
                if (name == want && pass != "") {
                    print pass
                }
            }
        ' "$profile"
    done | awk 'NF { print; exit }'
}

wait_for_saved_passphrase() {
    local elapsed=0
    while (( elapsed < WAIT_SECONDS )); do
        if [[ -n "$(find_saved_passphrase || true)" ]]; then
            return 0
        fi
        sleep 1
        ((elapsed+=1))
    done
    return 1
}

already_connected() {
    if iw dev "$IFACE" link 2>/dev/null | grep -qv "Not connected" &&
       ip -4 -o addr show dev "$IFACE" | grep -q .; then
        return 0
    fi
    return 1
}

if (( INITIAL_DELAY > 0 )); then
    log "sleeping ${INITIAL_DELAY}s before autoconnect"
    sleep "$INITIAL_DELAY"
fi

if already_connected; then
    log "interface already connected with IPv4, nothing to do"
    exit 0
fi

wait_for_iface
wait_for_shill
wait_for_saved_passphrase
log "starting WEXT helper for SSID '$SSID'"

exec "$CONNECT_SCRIPT" "$SSID"
